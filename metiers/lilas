<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Test Lilas</title>

<style>
:root{
  --bg:#2c2242;
  --bg-dark:#1f1830;
  --bg-deep:#151022;

  --text:#f4f1ea;
  --gold:#d7b16b;
}

body{
  margin:0;
  height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;

  background:
    radial-gradient(circle at top left, rgba(215,177,107,0.12), transparent 30%),
    linear-gradient(160deg, var(--bg-deep) 0%, var(--bg) 50%, #3a2c5c 100%);

  color:var(--text);
}

.box{
  padding:40px;
  border-radius:20px;
  background:rgba(255,255,255,0.08);
  border:1px solid rgba(255,255,255,0.15);
  text-align:center;
}

h1{
  margin:0 0 10px;
  color:var(--gold);
}

p{
  margin:0;
  opacity:0.8;
}
</style>

</head>
<body>

<div class="box">
  <h1>Test Lilas</h1>
  <p>Couleur RH</p>
</div>

</body>
</html>
